<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:orientation="vertical">

    <!-- Top bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <View
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentStart="true"
            android:background="#FFFFFF"
            android:layout_centerVertical="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:background="@drawable/bg_btn_round"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:text="@string/lich"
            android:textColor="@color/text_dark"
            android:textSize="14sp"/>

        <!-- Account icons -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@android:id/text1"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:paddingEnd="12dp">
                    <View android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/bg_card"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Sổ 1" android:textSize="12sp" android:paddingTop="4dp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:paddingEnd="12dp">
                    <View android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/bg_card"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Sổ 2" android:textSize="12sp" android:paddingTop="4dp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center">
                    <LinearLayout android:layout_width="56dp" android:layout_height="56dp"
                        android:background="@drawable/bg_card" android:gravity="center">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_add"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Thêm" android:textSize="12sp" android:paddingTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </HorizontalScrollView>
    </RelativeLayout>

    <!-- Calendar card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_card"
        android:layout_marginHorizontal="8dp"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Month selector -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="44dp">

            <TextView
                android:id="@+id/btn_prev_cal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="‹"
                android:textSize="24sp"
                android:textColor="@color/blue_primary"
                android:paddingHorizontal="8dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Spinner
                    android:id="@+id/spinner_month"
                    android:layout_width="100dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_input"/>

                <View android:layout_width="8dp" android:layout_height="1dp"/>

                <Spinner
                    android:id="@+id/spinner_year"
                    android:layout_width="100dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_input"/>
            </LinearLayout>

            <TextView
                android:id="@+id/btn_next_cal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="›"
                android:textSize="24sp"
                android:textColor="@color/blue_primary"
                android:paddingHorizontal="8dp"/>
        </RelativeLayout>

        <!-- Day headers -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center" android:text="Su" android:textColor="@color/text_gray" android:textSize="12sp"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center" android:text="Mo" android:textColor="@color/text_gray" android:textSize="12sp"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center" android:text="Tu" android:textColor="@color/text_gray" android:textSize="12sp"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center" android:text="We" android:textColor="@color/text_gray" android:textSize="12sp"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center" android:text="Th" android:textColor="@color/text_gray" android:textSize="12sp"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center" android:text="Fr" android:textColor="@color/text_gray" android:textSize="12sp"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center" android:text="Sa" android:textColor="@color/text_gray" android:textSize="12sp"/>
        </LinearLayout>

        <!-- Calendar Grid -->
        <androidx.gridlayout.widget.GridLayout
            android:id="@+id/calendar_grid"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:columnCount="7"
            app:rowCount="6"/>

        <!-- Filter tabs: Chi / Thu / Tổng -->
        <LinearLayout
            android:id="@+id/ll_filter"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_btn_category"
            android:orientation="horizontal"
            android:padding="4dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tab_chi"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/chi"
                android:textColor="@color/text_gray"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tab_thu"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_type_selected"
                android:gravity="center"
                android:text="@string/thu"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tab_tong"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/tong"
                android:textColor="@color/text_gray"
                android:textSize="14sp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
