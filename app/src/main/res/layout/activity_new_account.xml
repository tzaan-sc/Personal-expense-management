<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF7FF"
    android:orientation="vertical">

    <!-- Top bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/blue_primary"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/white"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Tài khoản mới"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btn_save"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:text="✓"
            android:textColor="@color/white"
            android:textSize="22sp"/>
    </RelativeLayout>

    <!-- Form -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:padding="0dp">

        <!-- Loại tài khoản -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:text="Loại tài khoản"
                android:textColor="@color/text_dark"
                android:textSize="15sp"/>

            <Spinner
                android:id="@+id/spinner_account_type"
                android:layout_width="180dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="12dp"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_alignParentBottom="true" android:background="#EEE"/>
        </RelativeLayout>

        <!-- Tên tài khoản -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:text="Tên tài khoản"
                android:textColor="@color/text_dark"
                android:textSize="15sp"/>

            <EditText
                android:id="@+id/et_account_name"
                android:layout_width="180dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_input"
                android:hint="..."
                android:paddingHorizontal="12dp"
                android:textColor="@color/text_dark"
                android:textSize="14sp"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_alignParentBottom="true" android:background="#EEE"/>
        </RelativeLayout>

        <!-- Số tiền -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:text="Số tiền"
                android:textColor="@color/text_dark"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/tv_amount"
                android:layout_width="180dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_input"
                android:gravity="center_vertical|end"
                android:paddingHorizontal="12dp"
                android:text="0 VND"
                android:textColor="@color/text_dark"
                android:textSize="14sp"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_alignParentBottom="true" android:background="#EEE"/>
        </RelativeLayout>

        <!-- Chọn sổ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:text="Chọn sổ"
                android:textColor="@color/text_dark"
                android:textSize="15sp"/>

            <Spinner
                android:id="@+id/spinner_so"
                android:layout_width="180dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="12dp"/>
        </RelativeLayout>
    </LinearLayout>

    <!-- Ghi chú -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ghi chú"
            android:textColor="@color/text_dark"
            android:textSize="15sp"
            android:paddingBottom="8dp"/>

        <EditText
            android:id="@+id/et_note"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/bg_input"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:maxLines="5"
            android:padding="12dp"
            android:textColor="@color/text_dark"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tv_note_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="0/30"
            android:textColor="@color/text_gray"
            android:textSize="12sp"
            android:paddingTop="4dp"/>
    </LinearLayout>

</LinearLayout>
